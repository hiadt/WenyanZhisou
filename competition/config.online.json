{
  "llm": {
    "provider": "none",
    "base_url": "",
    "api_key": "",
    "model": "",
    "temperature": 0.2,
    "max_tokens": 900,
    "timeout": 30
  },
  "small_models": {
    "embedding_model": "fallback",
    "reranker_model": "fallback",
    "device": "cpu",
    "embedding_batch_size": 32,
    "reranker_batch_size": 8
  },
  "retrieval": {
    "use_openalex": true,
    "use_semantic_scholar": true,
    "openalex_mailto": "",
    "semantic_scholar_api_key": "${SEMANTIC_SCHOLAR_API_KEY}",
    "academic_only": true,
    "local_corpus_path": "",
    "local_min_score": 0.0,
    "per_query": 20,
    "max_candidates": 80,
    "citation_expand_seeds": 4,
    "citation_expand_limit": 40,
    "max_rounds": 2
  },
  "ranking": {
    "api_weight": 0.05,
    "bm25_weight": 0.30,
    "embedding_weight": 0.25,
    "reranker_weight": 0.40,
    "llm_verifier_weight": 0.0,
    "authority_weight": 0.05,
    "recency_weight": 0.02,
    "diversity_weight": 0.01,
    "llm_verify_top_n": 0
  },
  "budget": {
    "max_llm_calls_per_query": 0,
    "max_api_calls_per_query": 16,
    "max_latency_seconds": 120
  }
